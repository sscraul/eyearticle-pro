# ─── LLM ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── APIs externas (opcionais) ───────────────────────────────────────────────
NCBI_API_KEY=your_ncbi_api_key_here
UNPAYWALL_EMAIL=your@email.com

# ─── CORS ────────────────────────────────────────────────────────────────────
# Em produção, coloque o(s) domínio(s) do seu frontend Vercel (separados por vírgula)
# Exemplo: https://eyearticle.vercel.app,https://meudominio.com
# Deixe vazio para permitir todos (apenas para dev local)
ALLOWED_ORIGINS=

# ─── Cloudflare R2 (storage persistente na nuvem) ────────────────────────────
# Obtenha em: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
# Necessário para fazer o app funcionar no Render (sem R2, arquivos são perdidos ao reiniciar)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=eyearticle-outputs
# URL pública do bucket - habilite em: R2 → seu bucket → Settings → Public Access
R2_PUBLIC_URL=https://pub-XXXXXXXXXXXXXXXX.r2.dev

# ─── App ─────────────────────────────────────────────────────────────────────
OUTPUT_DIR=./output
CACHE_DIR=./cache
LOG_LEVEL=INFO
DEFAULT_FORMAT=md
# Deletar PDF após processar (economiza espaço)
CLEANUP_AFTER=true
