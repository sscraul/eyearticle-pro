# ─── LLM ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── APIs externas (opcionais) ───────────────────────────────────────────────
NCBI_API_KEY=your_ncbi_api_key_here
UNPAYWALL_EMAIL=your@email.com

# ─── CORS ────────────────────────────────────────────────────────────────────
# Em produção, coloque o(s) domínio(s) do seu frontend Vercel (separados por vírgula)
# Exemplo: https://eyearticle.vercel.app,https://meudominio.com
# Deixe vazio para permitir todos (apenas dev local)
ALLOWED_ORIGINS=

# ─── Storage: Vercel Blob (RECOMENDADO — mais simples, 1 variável) ────────────
# Obtenha em: Vercel Dashboard → Storage → Create Database → Blob
# Depois: Settings → Tokens → Create Token (Read & Write)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_XXXXXXXXXXXXXXXX

# ─── Storage: Cloudflare R2 (alternativa — 10GB free, zero egress) ───────────
# Use R2 se preferir mais espaço ou não usar Vercel Blob.
# Obtenha em: dash.cloudflare.com → R2 → Manage R2 API Tokens
# (deixe vazio se usar Vercel Blob acima)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ─── App ─────────────────────────────────────────────────────────────────────
OUTPUT_DIR=./output
CACHE_DIR=./cache
LOG_LEVEL=INFO
DEFAULT_FORMAT=md
# Deletar PDF após processar (economiza espaço/memória no Render)
CLEANUP_AFTER=true
